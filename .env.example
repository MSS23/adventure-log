# Adventure Log - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# Never commit real secrets to version control!

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# PostgreSQL database connection string (Production recommended)
DATABASE_URL="postgresql://username:password@localhost:5432/adventure_log"

# SQLite database for local development (Alternative)
# DATABASE_URL="file:./dev.db"

# Shadow database URL for Prisma migrations (Optional - only needed for migration generation)
# SHADOW_DATABASE_URL="postgresql://username:password@localhost:5432/adventure_log_shadow"

# ==========================================
# NEXTAUTH CONFIGURATION
# ==========================================

# Your application URL - MUST match your deployment URL in production
NEXTAUTH_URL="http://localhost:3004"

# NextAuth secret for JWT encryption - Generate with: openssl rand -base64 32
# MUST be at least 32 characters - keep this secret!
NEXTAUTH_SECRET="your-32-character-or-longer-secret-key-here-change-me"

# Application URL (fallback if NEXTAUTH_URL not set)
# APP_URL="http://localhost:3004"

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================

# Google OAuth Client ID - Get from Google Cloud Console
# Format: YOUR_PROJECT-xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID="your-google-oauth-client-id"

# Google OAuth Client Secret - Get from Google Cloud Console  
# Format: GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# ==========================================
# SUPABASE STORAGE CONFIGURATION
# ==========================================

# Supabase project URL - Get from Supabase Dashboard > Settings > API
# Format: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase anonymous/public key - Get from Supabase Dashboard > Settings > API
# This is safe to expose in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anonymous-key"

# Supabase service role key - Get from Supabase Dashboard > Settings > API
# KEEP SECRET! Only use server-side - has full database access
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase storage bucket name for photos
NEXT_PUBLIC_SUPABASE_BUCKET="adventure-photos"

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Node environment (development, test, production)
NODE_ENV="development"

# PWA configuration
NEXT_PUBLIC_PWA_ENABLED="true"

# Mobile optimization
NEXT_PUBLIC_IS_MOBILE="auto"

# ==========================================
# OPTIONAL INTEGRATIONS
# ==========================================

# Slack webhook URL for error notifications (Optional)
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"

# Sentry DSN for error tracking (Optional)
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# ==========================================
# DEVELOPMENT & TESTING
# ==========================================

# Playwright base URL for E2E tests (Optional)
PLAYWRIGHT_BASE_URL="http://localhost:3004"

# CI environment detection (Automatically set in CI/CD)
# CI="true"

# ==========================================
# SETUP CHECKLIST
# ==========================================
# □ Copy this file to .env.local
# □ Fill in all required variables (marked as required above)
# □ Set up PostgreSQL database and update DATABASE_URL
# □ Create Google OAuth app and update GOOGLE_CLIENT_* vars
# □ Create Supabase project and update SUPABASE_* vars
# □ Generate secure NEXTAUTH_SECRET (32+ characters)
# □ Update NEXTAUTH_URL to match your domain in production
# □ Test: npm run dev should start without errors
# □ Test: Sign in with Google should work

# ==========================================
# QUICK START COMMANDS
# ==========================================
# 1. Copy environment file:
#    cp .env.example .env.local
#
# 2. Generate NEXTAUTH_SECRET:
#    openssl rand -base64 32
#
# 3. Start development server:
#    npm run dev
#
# 4. Set up database:
#    npm run db:push
#    npm run db:seed

# ==========================================
# PRODUCTION NOTES
# ==========================================
# - Never use SQLite in production - use PostgreSQL
# - NEXTAUTH_URL must match your deployed domain exactly
# - All secrets should be set in your hosting platform (Vercel, etc.)
# - Use strong passwords and regularly rotate secrets
# - Enable 2FA on all service accounts (Google, Supabase, etc.)

# ==========================================
# TROUBLESHOOTING
# ==========================================
# Common issues:
# - "NEXTAUTH_URL mismatch" → Check NEXTAUTH_URL matches your domain
# - "Google OAuth error" → Check redirect URLs in Google Console
# - "Database connection error" → Check DATABASE_URL format
# - "Supabase error" → Check all SUPABASE_* variables are correct
# - "Environment validation failed" → Check src/env.ts for requirements