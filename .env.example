# 🔐 PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your actual values

# ✅ REQUIRED - Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ✅ REQUIRED - Application URL
# Local development: http://localhost:3004
# Production: https://adventure-log-azure.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3004

# 📍 OPTIONAL - Mapbox for Enhanced Location Features
# Sign up at https://mapbox.com for free tier
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# 🤖 OPTIONAL - AI Trip Planner (Gemini is primary, GROQ is legacy fallback)
# Sign up at https://aistudio.google.com for free tier
GEMINI_API_KEY=your_gemini_api_key_here
# Legacy: GROQ_API_KEY=your_groq_api_key_here

# 🔄 OPTIONAL - Redis (Upstash) - For distributed rate limiting
# Sign up at https://upstash.com for free tier (10K commands/day)
# Required for production rate limiting across serverless instances
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# 📊 OPTIONAL - Sentry Error Monitoring
# Sign up at https://sentry.io for free tier (5K errors/month)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=adventure-log

# 🛡️ OPTIONAL - Image content moderation (NSFW detection)
# When unset, uploads work normally with no extra cost or network calls.
# When set, uploaded photos are checked server-side and flagged images are
# rejected and deleted. Currently supports Google Cloud Vision SafeSearch.
# MODERATION_PROVIDER=google-vision
# MODERATION_API_KEY=your_moderation_api_key_here

# 🔧 OPTIONAL - Maintenance/Cron Job Secret
# Required for /api/maintenance/cleanup endpoint
CRON_SECRET=your_cron_secret_here

# 💬 OPTIONAL - In-app feedback delivery (/api/feedback)
# Every submission is stored in the `feedback` table regardless. These wire the
# best-effort fan-out. Leave unset to disable that destination.
#
# Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Public invite link shown on the contact/settings pages (optional)
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite
#
# Linear: Settings → API → Personal API keys → create a key.
# Team ID: open the team, it's the UUID in the URL, or query `teams` in the API.
LINEAR_API_KEY=lin_api_xxx
LINEAR_TEAM_ID=your_linear_team_uuid
# Optional label UUID applied to every feedback issue
LINEAR_FEEDBACK_LABEL_ID=your_linear_label_uuid

# 📧 OPTIONAL - Public support email shown on the contact page (only if you have one)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# 🌍 PRODUCTION ENVIRONMENT
NODE_ENV=production