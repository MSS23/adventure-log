# Local development env. Copy to `.env.local` and fill in values.
# `.env.local` is git-ignored.

# ─────────────────────────────────────────────────────────────
# REQUIRED — Supabase
# Get these from Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only key (NEVER expose to client). Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────
# REQUIRED — App URL
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# REQUIRED for mobile builds (Capacitor) — base URL of the deployed
# web app, used by the WebView to call /api/* against the live server.
# Web builds ignore this (they always use same-origin relative paths).
#
# Read by `src/lib/api/client.ts` → apiUrl() / apiFetch(). On native,
# every `apiFetch('/api/foo')` becomes `${NEXT_PUBLIC_API_BASE_URL}/api/foo`.
# Must NOT have a trailing slash.
#
# Example for production: https://adventurelog.com
# Example for staging:    https://adventure-log-staging.vercel.app
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Mapbox (enhanced location search). Free tier: mapbox.com
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — AI trip planner. Either Groq or Gemini works.
# Groq:   https://console.groq.com
# Gemini: https://ai.google.dev
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Distributed rate limiting (Upstash Redis).
# Required in production for serverless deployments.
# Free tier (10K commands/day): https://upstash.com
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Sentry error monitoring. Free tier: https://sentry.io
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=adventure-log

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Maintenance cron secret (protects /api/maintenance/*)
# ─────────────────────────────────────────────────────────────
CRON_SECRET=
