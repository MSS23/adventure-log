# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
dist/cache/
dist/types/

# Mobile platform build artifacts
android/app/src/main/assets/public/
ios/App/App/public/
android/app/build/
ios/App/build/
android/.gradle/
android/app/src/main/assets/_next/
ios/App/App/_next/

# Large generated files
*.pack
*.chunk.js
*.chunk.css
*.map
*build-manifest.json
*loadable-manifest.json

# Mobile development files
android/local.properties
android/keystore.properties
ios/App/Podfile.lock
ios/App/Pods/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# Platform-specific generated content
android/capacitor.build.gradle
android/app/src/main/res/raw/
ios/App/App/capacitor.config.json

# Additional build artifacts that can cause large file issues
.next/static/chunks/
.next/cache/
dist/_next/static/chunks/pages/
dist/server/chunks/

# Temporary and build artifacts
type-errors.txt
nul
*.log

# Mobile build state — tracks file renames during MOBILE_BUILD so an
# interrupted build can be recovered (see scripts/mobile-build.mjs).
.mobile-build-renames.json
# Files renamed out of the build by mobile:build. Should never be committed —
# they're restored on every successful build, but a Ctrl+C could leave them.
*.mobile-skip

# Documentation archives
docs/archive/
database/archive/
database/deprecated/

# Development documentation (not for production)
*_FIX_*.md
*_CRITICAL_*.md
*_TESTING_*.md
*_MIGRATION_*.md
*_DEPLOYMENT_*.md
ADVENTURE_LOG_ARCHITECTURE.md
# Allow long-lived planning docs that happen to match the *_MIGRATION_* pattern.
!docs/CLERK_MIGRATION_PLAN.md
APP_README.md
supabase-deployment.sql

# Temporary cleanup and fix files
QUICK_FIX_GUIDE.md
REFACTORING_SUMMARY.md
SUPABASE_SETUP.md
database/CLEAR_USER_DATA*.sql
database/COMPLETE_PRODUCTION_SCHEMA.sql
database/FINAL_FIX.sql

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.claude/settings.local.json
.claude/worktrees/
.agent-runs/

# OS files
Thumbs.db
.DS_Store

# Screenshots / temp captures
screen/

# Python bytecode (ui-ux-pro-max skill)
__pycache__/
*.pyc

# Stray working-tree files dropped at repo root (never ship these)
/WhatsApp Image*.jpeg
/WhatsApp Image*.jpg
# Ad-hoc combined migration bundles staged for manual prod application.
# Canonical, tracked migrations live in supabase/migrations/ — these root
# bundles are operational scratch and must not be committed.
/prod-migrations-*.sql
/trip-planner-combined-migrations.sql
