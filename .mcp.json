{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${TWENTY_FIRST_API_KEY}"
      }
    }
  }
}
