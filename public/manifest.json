{
  "name": "Adventure Log - Social Travel Memories",
  "short_name": "Adventure Log",
  "description": "Capture your travels, relive them on a living globe, and discover meaningful places through people you trust.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#F8F7F3",
  "theme_color": "#1F6B57",
  "orientation": "any",
  "scope": "/",
  "id": "com.adventurelog.app",
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Adventure Log home - desktop view"
    },
    {
      "src": "/screenshots/mobile-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Adventure Log home - mobile view"
    }
  ],
  "shortcuts": [
    {
      "name": "Add a Memory",
      "short_name": "New Memory",
      "description": "Keep a travel memory with photos and places",
      "url": "/albums/new?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-new-album.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Relive Your Globe",
      "short_name": "Globe",
      "description": "Relive your travels on your interactive 3D globe",
      "url": "/globe?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-globe.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Trusted Discovery",
      "short_name": "Discover",
      "description": "See travel stories and places shared by people you trust",
      "url": "/feed?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-albums.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "categories": ["travel", "photography", "lifestyle", "social", "navigation"],
  "lang": "en-US",
  "dir": "ltr",
  "prefer_related_applications": false,
  "share_target": {
    "action": "/albums/new",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "notes",
      "url": "sharedUrl"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
